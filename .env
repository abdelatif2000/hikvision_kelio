# =============================================================
# HikVision SQL Server -> Kelio Integration - Configuration
# =============================================================
# --- SQL Server Database ---
DB_HOST=localhost
DB_USER=sa
DB_PASSWORD=manager
DB_NAME=HikVision
DB_TABLE=attLog
DB_DRIVER=ODBC Driver 17 for SQL Server

# --- Kelio SOAP Web Service ---
KELIO_SOAP_URL=https://demo-cbo.kelio.io/open/services/ClockingService?wsdl
KELIO_SOAP_LOGIN=d.chajid
KELIO_SOAP_PASSWORD=03914223

# --- Processing ---
BATCH_SIZE=100
LOG_LEVEL=INFO

# --- Absence DB (GEDRHP table) ---
ABSENCE_DB_HOST=localhost
ABSENCE_DB_USER=sa
ABSENCE_DB_PASSWORD=manager
ABSENCE_DB_NAME=Interface_GED_KELIO
ABSENCE_DB_DRIVER=ODBC Driver 17 for SQL Server
ABSENCE_DB_TABLE=GEDRHP
ABSENCE_MONTHS_BACK=3
# Comma-separated Code_Entite values to filter (empty = all entities)
ABSENCE_CODE_ENTITE=

# --- Kelio Absence SOAP Web Service ---
KELIO_ABSENCE_SOAP_URL=https://demo-cbo.kelio.io/open/services/AbsenceFileService?wsdl

# --- Employee Sync DB (local DB with write access) ---
EMPLOYEE_SYNC_DB_HOST=localhost
EMPLOYEE_SYNC_DB_USER=sa
EMPLOYEE_SYNC_DB_PASSWORD=manager
EMPLOYEE_SYNC_DB_NAME=Sync_interface_GED_KELIO
EMPLOYEE_SYNC_DB_DRIVER=ODBC Driver 17 for SQL Server
EMPLOYEE_SYNC_TABLE=EmployeeSync

# --- Employee Source (Collaborateur via Linked Server) ---
EMPLOYEE_SOURCE_LINKED_SERVER=SOURCE_SERVER_GEDRHP
EMPLOYEE_SOURCE_DB=Interface_GED_KELIO
EMPLOYEE_SOURCE_TABLE=Collaborateur
EMPLOYEE_DEFAULT_SECTION=ZTT
# Optional: filter employees by Date_Embauche >= this value. Leave empty to fetch all.
EMPLOYEE_DATE_EMBAUCHE_FROM=2026-02-13
# Comma-separated Entite_Juridique values to filter with LIKE %value% (empty = all)
EMPLOYEE_ENTITE_JURIDIQUE=

# --- Kelio Employee SOAP Web Services ---
KELIO_EMPLOYEE_SOAP_URL=https://demo-cbo.kelio.io/open/services/EmployeeService?wsdl
KELIO_EMPLOYEE_FIELD_SOAP_URL=https://demo-cbo.kelio.io/open/services/EmployeeFieldAssignmentService?wsdl


# --- SMTP Email Alerts ---
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_TO=
# Optional: leave empty for no authentication (internal relay)
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENABLED=true
